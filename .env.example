# ==============================================================================
# 🏢 SRI HARI BUILDER & PROMOTERS - ENVIRONMENT CONFIGURATION
# ==============================================================================
# ⚠️ INSTRUCTIONS:
# 1. Copy this file and rename it to '.env' or '.env.local'
# 2. Fill in the required API keys below securely.
# 3. DO NOT commit your actual '.env' file to Git!
# ==============================================================================

# ------------------------------------------------------------------------------
# ☁️ FIREBASE CONFIGURATION (Database & Real-time Sync)
# ------------------------------------------------------------------------------
# These keys connect the Admin Hub and Projects Gallery to your real-time database.
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain_here"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_firebase_project_id_here"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket_here"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_firebase_app_id_here"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your_firebase_measurement_id_here"

# ------------------------------------------------------------------------------
# 🖼️ CLOUDINARY CONFIGURATION (Admin Panel Image Uploads)
# ------------------------------------------------------------------------------
# These keys are required for uploading high-quality project images to your CDN.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"

# Server-Side Cloudinary Keys (Never expose these in client-side code)
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"

# ⚠️ UPLOAD SETTINGS
# IMPORTANT: You must create an 'Unsigned Upload Preset' in your Cloudinary Settings.
# Set its exact name below so the Admin Panel can upload images.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="shb_admin_uploads"
